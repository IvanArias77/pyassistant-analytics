# ===== Environment Variables Example =====
# Copy this file to .env and fill in your values

# Application
APP_NAME=PyAssistant Analytics
DEBUG=False
SECRET_KEY=change-me-in-production-please

# Database (SQLite default - perfect for Railway free tier)
DATABASE_URL=sqlite:///./data/pyassistant.db

# Google Gemini API (get free key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# CORS (origins allowed to access the API)
# For production, add your Railway domain here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Server (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=8000